"""
Finance Router — CRUD endpoints for accounts, loans, credit cards,
investments, goals, tax, alerts, cash, and business modules.
All mutations trigger recalculation.
"""
from decimal import Decimal
from typing import Optional
from fastapi import APIRouter, Depends, HTTPException, status, Query
from sqlalchemy.orm import Session
from app.database import get_db
from app.models.user import User
from app.models.bank_account import BankAccount
from app.models.loan import Loan
from app.models.credit_card import CreditCard
from app.models.investment import Investment
from app.models.goal import Goal
from app.models.tax import Tax
from app.models.alert import Alert
from app.models.cash import Cash
from app.models.business_inventory import BusinessInventory
from app.models.business_receivables import BusinessReceivable
from app.models.business_payables import BusinessPayable
from app.schemas.finance_schemas import (
    BankAccountCreate, BankAccountUpdate, BankAccountResponse,
    CashCreate, CashUpdate,
    LoanCreate, LoanUpdate, LoanResponse,
    CreditCardCreate, CreditCardUpdate, CreditCardResponse,
    InvestmentCreate, InvestmentUpdate, InvestmentResponse,
    GoalCreate, GoalUpdate, GoalResponse,
    TaxUpdate, TaxResponse,
    AlertResponse, SuccessResponse,
    InventoryCreate, ReceivableCreate, PayableCreate,
)
from app.schemas.user_schema import UpdateIncomeRequest
from app.security.auth_dependencies import get_current_user
from app.engines.recalculation_engine import recalculate_all_metrics
from app.engines import financial_calculations

router = APIRouter(tags=["Finance"])


def _recalc(user_id: int, db: Session):
    """Helper: trigger recalculation after any mutation."""
    recalculate_all_metrics(user_id, db)


# ═══════════════════════════════════════════
#  INCOME / EXPENSES
# ═══════════════════════════════════════════

@router.put("/income")
def update_income(
    request: UpdateIncomeRequest,
    current_user: User = Depends(get_current_user),
    db: Session = Depends(get_db),
):
    """Update monthly income and expenses."""
    if request.monthly_income is not None:
        current_user.monthly_income = Decimal(str(request.monthly_income))
    if request.monthly_expenses is not None:
        current_user.monthly_expenses = Decimal(str(request.monthly_expenses))
    if request.other_monthly_income is not None:
        current_user.other_monthly_income = Decimal(str(request.other_monthly_income))
    db.commit()
    _recalc(current_user.user_id, db)
    return {"success": True, "message": "Income updated and metrics recalculated"}


# ═══════════════════════════════════════════
#  BANK ACCOUNTS
# ═══════════════════════════════════════════

@router.get("/accounts")
def list_accounts(current_user: User = Depends(get_current_user), db: Session = Depends(get_db)):
    accounts = db.query(BankAccount).filter(BankAccount.user_id == current_user.user_id).all()
    return {
        "success": True,
        "data": {
            "accounts": [
                {"account_id": a.account_id, "bank_name": a.bank_name, "account_type": a.account_type,
                 "balance": float(a.balance or 0), "mode": a.mode}
                for a in accounts
            ],
            "total_balance": sum(float(a.balance or 0) for a in accounts),
        },
    }


@router.post("/accounts", status_code=201)
def create_account(body: BankAccountCreate, current_user: User = Depends(get_current_user), db: Session = Depends(get_db)):
    acc = BankAccount(user_id=current_user.user_id, bank_name=body.bank_name,
                      account_type=body.account_type, balance=Decimal(str(body.balance)), mode=body.mode)
    db.add(acc)
    db.commit()
    db.refresh(acc)
    _recalc(current_user.user_id, db)
    return {"success": True, "data": {"account_id": acc.account_id}, "message": "Account created"}


@router.put("/accounts/{account_id}")
def update_account(account_id: int, body: BankAccountUpdate, current_user: User = Depends(get_current_user), db: Session = Depends(get_db)):
    acc = db.query(BankAccount).filter(BankAccount.account_id == account_id, BankAccount.user_id == current_user.user_id).first()
    if not acc:
        raise HTTPException(404, "Account not found")
    if body.bank_name is not None:
        acc.bank_name = body.bank_name
    if body.account_type is not None:
        acc.account_type = body.account_type
    if body.balance is not None:
        acc.balance = Decimal(str(body.balance))
    db.commit()
    _recalc(current_user.user_id, db)
    return {"success": True, "message": "Account updated"}


@router.delete("/accounts/{account_id}")
def delete_account(account_id: int, current_user: User = Depends(get_current_user), db: Session = Depends(get_db)):
    acc = db.query(BankAccount).filter(BankAccount.account_id == account_id, BankAccount.user_id == current_user.user_id).first()
    if not acc:
        raise HTTPException(404, "Account not found")
    db.delete(acc)
    db.commit()
    _recalc(current_user.user_id, db)
    return {"success": True, "message": "Account deleted"}


# ═══════════════════════════════════════════
#  CASH
# ═══════════════════════════════════════════

@router.get("/cash")
def list_cash(current_user: User = Depends(get_current_user), db: Session = Depends(get_db)):
    records = db.query(Cash).filter(Cash.user_id == current_user.user_id).all()
    return {"success": True, "data": [{"cash_id": c.cash_id, "amount": float(c.amount or 0), "mode": c.mode} for c in records]}


@router.post("/cash", status_code=201)
def upsert_cash(body: CashCreate, current_user: User = Depends(get_current_user), db: Session = Depends(get_db)):
    existing = db.query(Cash).filter(Cash.user_id == current_user.user_id, Cash.mode == body.mode).first()
    if existing:
        existing.amount = Decimal(str(body.amount))
        if body.description:
            existing.description = body.description
    else:
        existing = Cash(user_id=current_user.user_id, amount=Decimal(str(body.amount)), mode=body.mode, description=body.description)
        db.add(existing)
    db.commit()
    _recalc(current_user.user_id, db)
    return {"success": True, "message": "Cash updated"}


